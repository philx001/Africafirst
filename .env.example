# ============================================================
# SUPABASE — Project Settings → API / JWT Keys (Legacy JWT Secret)
# ============================================================
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ============================================================
# BASE PRISMA — Connect → ORM → Prisma (copier les URI sans guillemets)
# VARIABLE OBLIGATOIRE : DATABASE_DIRECT_URL (pas DIRECT_URL)
# Remplace [YOUR-PASSWORD] par ton mot de passe ; pas de crochets [ ] dans l’URI.
# Si le MDP contient @ ! etc., utilise les chaînes générées par Supabase après saisie du MDP.
# ============================================================
DATABASE_URL=
DATABASE_DIRECT_URL=

# ============================================================
# REDIS (local via Docker / production avec mot de passe)
# Dev : redis://localhost:6379 (sans mot de passe)
# Prod : redis://:MOT_DE_PASSE@redis:6379 (défini dans docker-compose.prod.yml)
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001

# ============================================================
# DÉVELOPPEMENT LOCAL UNIQUEMENT — ne jamais activer en production / CI / Docker prod
# Si TLS vers Supabase échoue (proxy/antivirus), voir docs/CONFIGURATION_ENVIRONNEMENT.md §5.b
# Préférez NODE_EXTRA_CA_CERTS une fois le certificat racine installé.
# ============================================================
# CRM_DEV_INSECURE_TLS=1

# ============================================================
# NEXT.JS (variables publiques — aussi dans apps/web/.env.local pour next dev)
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Front : déconnexion après X ms sans interaction (défaut 900000 = 15 min)
# À aligner avec Supabase → Authentication → Settings → JWT expiry (recommandé ≥ 900 s)
#NEXT_PUBLIC_SESSION_IDLE_TIMEOUT_MS=900000

# ============================================================
# STOCKAGE (bucket names dans Supabase Storage)
# Créer ces buckets dans Supabase Dashboard > Storage avant le premier démarrage.
# Appliquer les politiques RLS via docs/supabase-storage-documents-rls.sql
# ============================================================
SUPABASE_STORAGE_BUCKET_DOCUMENTS=documents
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
# Bucket privé pour les exports CSV planifiés (interne uniquement)
SUPABASE_STORAGE_BUCKET_EXPORTS=exports

# ============================================================
# SÉCURITÉ (chaînes aléatoires longues pour le dev, plus fortes en prod)
# ============================================================
JWT_COOKIE_SECRET=change-me-in-production-32-chars-min

# ============================================================
# WEBHOOKS SORTANTS
# ============================================================
WEBHOOK_SECRET=change-me-webhook-secret
